# Do not commit real secrets.

# Shared OpenAI-compatible API (works with OpenRouter, OpenAI, etc.)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://openrouter.ai/api/v1

CRITIC_MODEL=google/gemini-3.1-flash-lite
CRITIC_TOP_N=5
CRITIC_LOG_FILE=logs/critic.log
# Optional. Inference logs store the submitted document text. Enable only when
# that is acceptable for your environment.
# CRITIC_INFERENCE_LOG_FILE=logs/inference.jsonl

# Optional: override the packaged 50-point checklist.
CRITIC_CHECKLIST_PATH=

ASSESSOR_MODEL=google/gemini-3.1-flash-lite
ASSESSOR_EVAL_LOG_FILE=logs/assessment-eval.jsonl
# Optional: override the packaged 9-point assessor checklist.
ASSESSOR_CHECKLIST_PATH=
