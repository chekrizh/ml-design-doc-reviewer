# Do not commit real secrets.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://openrouter.ai/api/v1
CRITIC_MODEL=openai/gpt-4o-mini
CRITIC_TOP_N=5
CRITIC_LOG_FILE=logs/critic.log
# Inference logs store the submitted document text. Do not enable them for sensitive docs
# unless that is acceptable for your environment.
CRITIC_INFERENCE_LOG_FILE=logs/inference.jsonl

# Optional: override the packaged 38-point checklist.
CRITIC_CHECKLIST_PATH=
