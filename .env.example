# OpenRouter (required for normalize step)
OPENROUTER_API_KEY=your_openrouter_api_key

# Free OpenRouter model (swap to a paid model for higher quality / limits)
# google/gemma-4-31b-it:free
# openrouter/free
OPENROUTER_MODEL=google/gemma-4-31b-it:free
OPENROUTER_MAX_TOKENS=8192
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Whisper (CPU-friendly defaults for video transcription)
WHISPER_MODEL=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# Paths (defaults are relative to project root)
DATA_DIR=./data
CASES_CSV=./data/evidently_ai_cases/800 ML and LLM use cases.csv
SAMPLE_MANIFEST_PATH=./data/sample_manifest.csv
RAW_DOCUMENTS_DIR=./data/raw_documents
NORMALIZED_DISDOCS_DIR=./data/normalized_disdocs
DISDOC_EXAMPLES_DIR=./data/disdoc_examples
NORMALIZE_PROMPT_PATH=./prompts/normalize_to_disdoc.md
ERROR_TOPOLOGY_PATH=./data/error_topology.csv
FLAWED_DISDOCS_DIR=./data/flawed_disdocs
INJECTION_LOG_PATH=./data/flawed_disdocs/injection_log.csv

# Sampling
SAMPLE_SIZE=100
RANDOM_SEED=42

# Optional: browser name for yt-dlp cookies when YouTube blocks automated access (e.g. chrome, firefox)
# YOUTUBE_COOKIES_FROM_BROWSER=chrome

# Fetch behavior
FETCH_TIMEOUT_SECONDS=30
FETCH_DELAY_SECONDS=2.0

# Tesseract OCR (system binary required: brew install tesseract)
# TESSERACT_CMD=/opt/homebrew/bin/tesseract
TESSERACT_LANG=eng

# Delay between OpenRouter normalization calls (helps free-tier rate limits)
NORMALIZE_DELAY_SECONDS=3.0

# Hugging Face dataset (heavy artifacts: raw/normalized/flawed docs + images)
HF_DATASET_REPO=chekrizh/ml-disdoc-eval
HF_DATASET_REVISION=v1.0.0
# HF_TOKEN=your_huggingface_token
